generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model VisitorLog {
  id        Int      @id @default(autoincrement())
  ip        String
  userAgent String?
  path      String?
  createdAt DateTime @default(now())
}

model AdminSession {
  id        Int      @id @default(autoincrement())
  ip        String
  loginTime DateTime @default(now())
}
